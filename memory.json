{
  "version": 2,
  "user": {
    "preferences": {}
  },
  "strict": {
    "forbiddenCommands": [
      {
        "id": "no-rf-root",
        "pattern": "rm\\s+-rf\\s+/",
        "description": "禁止递归删除根目录",
        "severity": "critical"
      },
      {
        "id": "no-rf-drive",
        "pattern": "rm\\s+-rf\\s+[A-Za-z]:",
        "description": "禁止删除整个盘符",
        "severity": "critical"
      },
      {
        "id": "no-format-drive",
        "pattern": "format\\s+[A-Za-z]:",
        "description": "禁止格式化盘符",
        "severity": "critical"
      },
      {
        "id": "no-del-system",
        "pattern": "del\\s+/[fqs]\\s+/",
        "description": "禁止强制删除系统目录",
        "severity": "critical"
      }
    ],
    "rules": [
      "执行删除操作前必须确认路径",
      "执行危险命令前必须使用 --WhatIf 或类似预览参数",
      "涉及多文件操作前先列出将受影响文件"
    ]
  },
  "projects": {}
}